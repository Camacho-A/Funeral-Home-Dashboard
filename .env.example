# Beacon environment variables.
# Copy this file to .env.local (gitignored) and fill in real values as needed.
# See docs/WIX_INTEGRATION.md for the full reference, including local/preview/
# production configuration and what each variable actually does today.

# --- Data adapter (docs/WIX_INTEGRATION.md, docs/adr/ADR-007-wix-integration-foundation.md) ---
# "mock" (default if unset) — every service reads services/__mocks__/fixtures.ts,
# exactly as it has since Phase 4. No Wix variables below are required in this mode,
# and next build succeeds without any of them set.
# "wix" — enables app/api/wix-health's connectivity check against a real Wix
# project. Application services still don't call Wix yet (see ADR-007) — this
# only proves the server can authenticate, ahead of Phase 13 actually using it.
DATA_ADAPTER=mock

# --- Wix Headless, self-managed (docs/WIX_INTEGRATION.md) ---
# Required only when DATA_ADAPTER=wix. WIX_API_KEY is a secret — server-side only,
# never exposed to the browser (see lib/wixClient.ts). Generate it yourself in the
# Wix dashboard's API Keys manager; Claude does not create or handle this value.
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=

# --- Compliance/document service: Postgres + object storage (docs/ARCHITECTURE.md) — not used yet ---
DATABASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Session (docs/ARCHITECTURE.md — Wix Members session -> first-party JWT) — not used yet ---
SESSION_JWT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mock organization used throughout this frontend-only phase ---
# See docs/adr/ADR-002-multi-tenant-architecture.md. Every service call is scoped by
# organizationId; this is the single value used until a second organization exists.
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=managed-cremations
