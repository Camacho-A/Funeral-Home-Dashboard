# Beacon environment variables.
# Copy this file to .env.local (gitignored) and fill in real values as needed.
# See docs/WIX_INTEGRATION.md for the full reference, including local/preview/
# production configuration and what each variable actually does today.

# --- Data adapter (docs/WIX_INTEGRATION.md, docs/adr/ADR-007-wix-integration-foundation.md) ---
# Controls DATA access ONLY (which backend services/* read/write against) —
# independent of AUTH_ADAPTER below, which controls login (see
# docs/adr/ADR-011-auth-data-adapter-separation.md for why they were split).
# "mock" (default if unset) — every service reads services/__mocks__/fixtures.ts,
# exactly as it has since Phase 4. No Wix variables below are required in this mode,
# and next build succeeds without any of them set.
# "wix" — reads (organizations today; more in later phases) come from the real
# Wix project. Writes still go to mocks until Phase 16.
DATA_ADAPTER=mock

# --- Auth adapter (docs/AUTHENTICATION.md, docs/adr/ADR-011-auth-data-adapter-separation.md) ---
# Controls AUTHENTICATION ONLY (which login provider app/login uses) —
# independent of DATA_ADAPTER above. Defaults to "mock" for developer
# convenience if unset.
# "mock" — the existing mock login (dana@managedcremations.test / mock-password-not-real).
# "wix" — the existing Wix Members login (lib/auth/wixAuth.ts), requires WIX_OAUTH_CLIENT_ID below.
# Recommended local development combination: DATA_ADAPTER=wix, AUTH_ADAPTER=mock
# (real Wix-backed data, without needing a real Wix member account yet).
AUTH_ADAPTER=mock

# --- Wix Headless, self-managed (docs/WIX_INTEGRATION.md) ---
# Required only when DATA_ADAPTER=wix. WIX_API_KEY is a secret — server-side only,
# never exposed to the browser (see lib/wixClient.ts). Generate it yourself in the
# Wix dashboard's API Keys manager; Claude does not create or handle this value.
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=

# --- Compliance/document service: Postgres + object storage (docs/ARCHITECTURE.md) — not used yet ---
DATABASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Session (docs/AUTHENTICATION.md) ---
# The signing key for Beacon's own session cookie (lib/auth/sessionToken.ts).
# Falls back to a fixed, clearly-insecure development value outside production
# (see lib/env.ts's getSessionSecret) so mock mode needs nothing set here — but
# a real, random value is required in production, and the app refuses to start
# without one there.
SESSION_JWT_SECRET=

# --- Wix Headless member login (docs/AUTHENTICATION.md) ---
# Required only when AUTH_ADAPTER=wix. No client secret is needed —
# headless member OAuth uses only a Client ID. Not created by Claude; see
# docs/AUTHENTICATION.md's "Wix dashboard setup" section, which was
# presented for approval, not acted on.
WIX_OAUTH_CLIENT_ID=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mock organization used throughout this frontend-only phase ---
# See docs/adr/ADR-002-multi-tenant-architecture.md. Every service call is scoped by
# organizationId; this is the single value used until a second organization exists.
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=managed-cremations
