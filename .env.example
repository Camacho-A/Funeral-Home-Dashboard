# Beacon environment variables.
# Copy this file to .env.local and fill in real values once the backend-integration
# phase begins (see docs/ARCHITECTURE.md). Nothing below is read by the app yet in
# this frontend-only phase — services run entirely against mock fixtures
# (services/__mocks__/fixtures.ts). Reserved here so the shape is settled in advance.

# --- Wix Managed Headless (docs/ARCHITECTURE.md, docs/CMS_SCHEMA.md) — not used yet ---
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=

# --- Compliance/document service: Postgres + object storage (docs/ARCHITECTURE.md) — not used yet ---
DATABASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Session (docs/ARCHITECTURE.md — Wix Members session -> first-party JWT) — not used yet ---
SESSION_JWT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mock organization used throughout this frontend-only phase ---
# See docs/adr/ADR-002-multi-tenant-architecture.md. Every service call is scoped by
# organizationId; this is the single value used until a second organization exists.
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=managed-cremations
